{
  "name": "app",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "android:debug": "expo run:android --variant debug",
    "android:release": "expo run:android --variant release",
    "build:apk": "JAVA_HOME=/usr/lib/jvm/java-17-openjdk cd android && ./gradlew assembleRelease && echo '\n✅ APK: android/app/build/outputs/apk/release/app-release.apk'",
    "build:apk:debug": "JAVA_HOME=/usr/lib/jvm/java-17-openjdk cd android && ./gradlew assembleDebug && echo '\n✅ APK: android/app/build/outputs/apk/debug/app-debug.apk'",
    "serve:apk": "cd android/app/build/outputs/apk/release && python3 -m http.server 8899",
    "serve:apk:debug": "cd android/app/build/outputs/apk/debug && python3 -m http.server 8899"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@lobehub/icons-rn": "^2.5.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "^55.0.15",
    "expo-camera": "~55.0.15",
    "expo-clipboard": "~55.0.13",
    "expo-constants": "~55.0.14",
    "expo-crypto": "~55.0.14",
    "expo-device": "~55.0.15",
    "expo-document-picker": "~55.0.13",
    "expo-font": "~55.0.6",
    "expo-haptics": "~55.0.14",
    "expo-linking": "~55.0.13",
    "expo-notifications": "~55.0.19",
    "expo-router": "~55.0.12",
    "expo-secure-store": "~55.0.13",
    "expo-status-bar": "~55.0.5",
    "react": "19.2.0",
    "react-native": "0.83.4",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.16.0",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~5.9.2"
  },
  "private": true
}
